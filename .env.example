# ─── Backend (Python FastAPI on Railway) ───────────────────────────────────────
# Used by TanStack Start server functions (server-side only).
# Set this in Vercel dashboard → Project → Settings → Environment Variables
PYTHON_URL=https://your-app.railway.app

# ─── Client-side (exposed to browser via Vite) ─────────────────────────────────
# Used by proxy-image.ts to construct image proxy URLs in the browser.
# Must start with VITE_ to be exposed by Vite.
VITE_PYTHON_URL=https://your-app.railway.app

# ─── Local development (copy to .env.local and fill in) ────────────────────────
# PYTHON_URL=http://127.0.0.1:8000
# VITE_PYTHON_URL=http://127.0.0.1:8000
